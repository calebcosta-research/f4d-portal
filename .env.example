# Copy this file to .env and fill in values. .env is gitignored.
#
# --- Database backend selection ---
# sqlite = local single-file DB for development (no server needed)
# mssql  = SQL Server via pyodbc (production)
db_backend=sqlite

# Schema namespace. Leave BLANK for sqlite. For SQL Server use:
#   db_schema=TF_RESULTS_REPORTING
db_schema=

# SQLite database file (only used when db_backend=sqlite)
sqlite_path=f4d.db

# --- SQL Server connection (only used when db_backend=mssql) ---
sql_username=
sql_password=
sql_host=
sql_port=1433
sql_database=

# --- Application admin logins ---
# NOTE: passwords are currently stored/compared in plaintext (a known issue
# slated for fixing). Do not reuse real credentials here.
super_admin_username=superadmin
super_admin_password=change-me
f4d_admin_username=f4dadmin
f4d_admin_password=change-me
